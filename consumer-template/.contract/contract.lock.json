{
  "version": "1.0.0",
  "network": [
    "shared-net"
  ],
  "services": {
    "mongo": {
      "container_name": "shared-mongo",
      "image": "mongo:8.0",
      "image_major": "8",
      "host_ports": [
        "27017"
      ],
      "internal_ports": [
        "27017"
      ],
      "networks": [
        "shared-net"
      ]
    },
    "etcd": {
      "container_name": "shared-etcd",
      "image": "quay.io/coreos/etcd:v3.5.5",
      "image_major": "3",
      "host_ports": [],
      "internal_ports": [],
      "networks": [
        "shared-net"
      ]
    },
    "minio": {
      "container_name": "shared-minio",
      "image": "minio/minio:RELEASE.2023-03-20T20-16-18Z",
      "image_major": "RELEASE.2023-03-20T20-16-18Z",
      "host_ports": [
        "9000",
        "9001"
      ],
      "internal_ports": [
        "9000",
        "9001"
      ],
      "networks": [
        "shared-net"
      ]
    },
    "milvus": {
      "container_name": "shared-milvus",
      "image": "milvusdb/milvus:v2.3.3",
      "image_major": "2",
      "host_ports": [
        "19530",
        "9091"
      ],
      "internal_ports": [
        "19530",
        "9091"
      ],
      "networks": [
        "shared-net"
      ]
    },
    "fuseki": {
      "container_name": "shared-fuseki",
      "image": "stain/jena-fuseki:5.1.0",
      "image_major": "5",
      "host_ports": [
        "3030"
      ],
      "internal_ports": [
        "3030"
      ],
      "networks": [
        "shared-net"
      ]
    },
    "neo4j": {
      "container_name": "shared-neo4j",
      "image": "neo4j:5.15.0",
      "image_major": "5",
      "host_ports": [
        "7474",
        "7687"
      ],
      "internal_ports": [
        "7474",
        "7687"
      ],
      "networks": [
        "shared-net"
      ]
    },
    "redis": {
      "container_name": "shared-redis",
      "image": "redis:7-alpine",
      "image_major": "7",
      "host_ports": [
        "6379"
      ],
      "internal_ports": [
        "6379"
      ],
      "networks": [
        "shared-net"
      ]
    }
  },
  "mongo_users": {
    "ragaas": "ragaas_app",
    "gojira": "gojira_app"
  },
  "env_keys": [
    "FUSEKI_ADMIN_PASSWORD",
    "GOJIRA_MONGO_PASSWORD",
    "MINIO_ACCESS_KEY",
    "MINIO_SECRET_KEY",
    "MONGO_ROOT_PASSWORD",
    "MONGO_ROOT_USER",
    "NEO4J_PASSWORD",
    "RAGAAS_MONGO_PASSWORD"
  ]
}