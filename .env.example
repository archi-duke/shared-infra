# 복사해서 .env 로 사용: cp .env.example .env
# 운영(폐쇄망) 배포 시 반드시 전부 교체할 것

# MongoDB
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=example
# 앱별 계정 비밀번호 (최초 기동 시 init 스크립트가 계정 생성에 사용)
RAGAAS_MONGO_PASSWORD=ragaas-dev-pass
GOJIRA_MONGO_PASSWORD=gojira-dev-pass

# MinIO (Milvus 오브젝트 스토리지)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Graph DB
FUSEKI_ADMIN_PASSWORD=admin
NEO4J_PASSWORD=password
